{
    "$schema": "https://turborepo.org/schema.json",
    "pipeline": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "test": {},
        "dev:chrome": {
            "dependsOn": ["^build"],
            "cache": false,
            "persistent": true
        },
        "build:chrome": {
            "dependsOn": ["^build"],
            "outputs": ["build/chrome/**"]
        },
        "pack:chrome": {
            "dependsOn": ["^build"],
            "outputs": ["build/**.zip"]
        }
    }
}
