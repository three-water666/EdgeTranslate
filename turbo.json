{
    "$schema": "https://turborepo.org/schema.json",
    "pipeline": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "build/**"]
        },
        "test": {
            "inputs": [
                "src/**",
                "test/**",
                "package.json",
                "jest.config.*",
                "*.config.js",
                "*.config.ts",
                "*.setup.js"
            ],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "package": {
            "dependsOn": ["build", "^build"],
            "outputs": ["artifacts/**"]
        }
    }
}
