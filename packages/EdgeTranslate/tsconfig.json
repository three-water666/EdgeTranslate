{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "common/*": ["./common/*"],
      "@/*": ["./*"]
    },
    "noImplicitAny": false,
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": ["wxt/client", "chrome", "vite/client"]
  },
  "include": [
    "entrypoints/**/*",
    "components/**/*",
    "common/**/*",
    "utils/**/*",
    "wxt.config.ts",
    ".wxt/wxt.d.ts",
    ".wxt/types/**/*"
  ],
  "exclude": ["node_modules", ".wxt", "**/*.test.ts"]
}
