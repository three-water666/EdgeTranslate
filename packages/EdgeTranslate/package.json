{
    "name": "edge_translate",
    "version": "3.2.4",
    "private": true,
    "scripts": {
        "test": "jest",
        "lint": "node ../../scripts/run-eslint.js packages/EdgeTranslate .eslintrc.js \"scripts/**/*.js\" \"src/**/*.{js,jsx}\" \"config/**/*.js\" \"utils/**/*.js\" \"test/**/*.{js,jsx}\"",
        "lint:fix": "pnpm lint --fix",
        "format": "node ../../scripts/run-eslint.js packages/EdgeTranslate \"src/**/*.js\" \"config/**/*.js\" --fix",
        "dev": "pnpm --dir ../translators dev:prepare && node ./scripts/build-extension.js dev --browser chrome",
        "build": "node ./scripts/build-extension.js build --browser chrome",
        "package": "node -e \"console.log('\\npacking package for chrome')\" && node ./scripts/build-extension.js package --browser chrome",
        "e2e": "pnpm run e2e:chrome:functional",
        "e2e:functional": "pnpm run e2e:chrome:functional",
        "e2e:visual": "pnpm run e2e:chrome:visual",
        "e2e:chrome:functional": "node ./test/e2e/run.js --mode=functional --browser=chrome",
        "e2e:chrome:visual": "node ./test/e2e/run.js --mode=visual --browser=chrome",
        "e2e:edge": "pnpm run e2e:edge:functional",
        "e2e:edge:functional": "node ./test/e2e/run.js --mode=functional --browser=edge",
        "e2e:edge:visual": "node ./test/e2e/run.js --mode=visual --browser=edge"
    },
    "devDependencies": {
        "@babel/core": "^7.17.7",
        "@babel/eslint-parser": "^7.17.0",
        "@babel/plugin-transform-react-jsx": "^7.17.3",
        "@babel/preset-env": "^7.16.11",
        "@svgr/webpack": "^5.5.0",
        "adm-zip": "^0.5.9",
        "axios": "^1.16.1",
        "babel-loader": "^8.2.3",
        "chromedriver": "^147.0.4",
        "css": "^3.0.0",
        "edgedriver": "^6.3.0",
        "jest-image-snapshot": "^6.5.2",
        "mockttp": "^1.2.2",
        "selenium-webdriver": "^4.43.0",
        "socks-proxy-agent": "^10.0.0",
        "stylus": "^0.64.0",
        "terser": "^5.46.1",
        "webpack": "^5.70.0",
        "webpack-merge": "^5.8.0"
    },
    "dependencies": {
        "@edge_translate/translators": "workspace:^",
        "dompurify": "^3.4.0",
        "pdfjs-dist": "5.7.284",
        "preact": "^10.6.6",
        "preact-render-to-string": "^5.1.20",
        "react-shadow": "^19.0.2",
        "react-use": "^17.3.2",
        "resize-observer-polyfill": "^1.5.1",
        "simplebar-react": "^2.3.6",
        "styled-components": "5.3.0",
        "tesseract.js": "^7.0.0",
        "tesseract.js-core": "^7.0.0"
    }
}
