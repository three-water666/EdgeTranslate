@import '../common/style/input.styl';

html, body {
    width: 100%;
    padding: 0;
    margin: 0;
    background-color: #eeeeee;
}

#option {
    padding: 0 10%;
    margin: auto;
    max-width: 840px;
    margin: 0px auto;
    box-shadow: 0px 0px 50px rgb(200, 200, 200, 0.5);
    background-color: white;
}

header {
    width: 100%;
    height: 25%;
    padding: 5% 0;
    font-size: 64px;
    font-weight: bold;
    color: color-primary;
    display: flex;
    align-items: center;
}

.row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    line-height: 4em;
    margin: 3% 5%;
    flex: 1 1;
}

.column {
    display: flex;
    align-items: center;
    min-width: 30%;
    max-width: 70%;
}

.checked-label {
    cursor: pointer;
    font-size: medium;
    flex: 3 3 50%;
    justify-content: space-between;
}

.radio-label {
    cursor: pointer;
    font-size: medium;
}

.setting-title {
    font-size: large;
    font-weight: bold;
}

.setting-note {
    margin: 1% 5% 0;
    color: #666;
    font-size: 14px;
    line-height: 1.6;
}

#ocr-download-manager {
    margin: 0 5% 3%;
}

.ocr-download-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
    border-bottom: 1px solid #eee;
}

.ocr-download-title {
    flex: 1 1 auto;
}

.ocr-download-status {
    color: #666;
    min-width: 60px;
    text-align: right;
}

.ocr-download-actions {
    display: flex;
    gap: 8px;
}

.ocr-download-progress {
    margin: -4px 0 10px;
    height: 6px;
    background: #ececec;
    border-radius: 999px;
    overflow: hidden;
}

.ocr-download-progress-bar {
    height: 100%;
    background: color-primary;
    transition: width 0.2s linear;
}

.ocr-action-button {
    border: none;
    border-radius: 6px;
    padding: 6px 12px;
    background: color-primary;
    color: white;
    cursor: pointer;
}

.ocr-action-button.secondary {
    background: #e8e8e8;
    color: #333;
}

.ocr-action-button:disabled {
    opacity: 0.6;
    cursor: default;
}

.ocr-download-error {
    margin-top: 8px;
    color: #c0392b;
    font-size: 13px;
}

.ocr-download-error.inline {
    margin-top: -4px;
    margin-bottom: 8px;
}

.space {
    display: inline-block;
    width: 5px;
}

footer {
    padding: 5% 0;
    text-align: center;
    font-size: medium;
}

.footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.github-icon {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
}
