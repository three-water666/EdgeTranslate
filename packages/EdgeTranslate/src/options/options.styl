@import '../common/style/input.styl';

html, body {
    width: 100%;
    padding: 0;
    margin: 0;
    background-color: #eeeeee;
}

#option {
    padding: 0 10%;
    margin: auto;
    max-width: 840px;
    margin: 0px auto;
    box-shadow: 0px 0px 50px rgb(200, 200, 200, 0.5);
    background-color: white;
}

header {
    width: 100%;
    height: 25%;
    padding: 5% 0;
    font-size: 64px;
    font-weight: bold;
    color: color-primary;
    display: flex;
    align-items: center;
}

.row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    line-height: 4em;
    margin: 3% 5%;
    flex: 1 1;
}

.column {
    display: flex;
    align-items: center;
    min-width: 30%;
    max-width: 70%;
}

#layout-settings .row {
    gap: 24px;
}

#layout-settings .column {
    flex: 1 1 0;
    min-width: 0;
    max-width: none;
}

.checked-label {
    cursor: pointer;
    font-size: medium;
    flex: 3 3 50%;
    justify-content: space-between;
}

.radio-label {
    cursor: pointer;
    font-size: medium;
}

.setting-title {
    font-size: large;
    font-weight: bold;
}

.setting-anchor {
    display: block;
    scroll-margin-top: 20px;
}

.setting-note {
    margin: 1% 5% 0;
    color: #666;
    font-size: 14px;
    line-height: 1.6;
    text-indent: 0;
    padding-left: 0;
    text-align: left;
}

#pdf-file-access-status {
    display: flex;
    align-items: center;
    gap: 12px;
    box-sizing: border-box;
    padding: 10px 12px;
    border: 1px solid #e2e2e2;
    border-left: 4px solid #d8d8d8;
    border-radius: 6px;
    background: #fafafa;
}

#pdf-file-access-status[hidden] {
    display: none;
}

#pdf-file-access-status.allowed {
    border-left-color: #2e9d57;
}

#pdf-file-access-status.missing {
    border-left-color: color-primary;
}

#pdf-file-access-status-text {
    flex: 1 1 auto;
}

.pdf-file-access-button {
    flex: 0 0 auto;
    border: none;
    border-radius: 6px;
    padding: 6px 12px;
    background: color-primary;
    color: white;
    cursor: pointer;
}

#ocr-download-manager {
    margin: 0 5% 3%;
}

.ocr-search-input {
    width: 100%;
    box-sizing: border-box;
    margin: 10px 0 14px;
    padding: 10px 12px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    font-size: 14px;
}

.ocr-filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin: 0 0 14px;
}

.ocr-filter-chip {
    border: 1px solid #d8d8d8;
    background: #fff;
    color: #555;
    border-radius: 999px;
    padding: 6px 12px;
    font-size: 12px;
    cursor: pointer;
}

.ocr-filter-chip.active {
    border-color: color-primary;
    background: rgba(74, 140, 247, 0.1);
    color: color-primary;
}

.ocr-download-list {
    max-height: 620px;
    overflow-y: auto;
    padding-right: 4px;
}

.ocr-download-card {
    background: #fafafa;
    border: 1px solid #ececec;
    border-left: 4px solid #d8d8d8;
    border-radius: 10px;
    padding: 12px 14px;
    margin-bottom: 12px;
}

.ocr-download-card.enabled {
    border-left-color: #2e9d57;
}

.ocr-download-card.downloaded {
    border-left-color: color-primary;
}

.ocr-download-card.downloading {
    border-left-color: #2f80ed;
}

.ocr-download-card.error {
    border-left-color: #c0392b;
}

.ocr-download-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0;
}

.ocr-download-title {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    flex: 1 1 auto;
    min-width: 0;
}

.ocr-download-name {
    flex: 0 1 auto;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.ocr-download-status {
    display: inline-flex;
    align-items: center;
    justify-content: flex-end;
    gap: 5px;
    min-width: 150px;
    text-align: right;
    white-space: nowrap;
}

.ocr-status-badge {
    display: inline-flex;
    align-items: center;
    min-height: 22px;
    box-sizing: border-box;
    border: 1px solid #d8d8d8;
    border-radius: 999px;
    padding: 2px 8px;
    font-size: 12px;
    line-height: 1.4;
    color: #555;
    background: #f2f2f2;
}

.ocr-status-badge.downloaded {
    border-color: rgba(74, 140, 247, 0.35);
    background: rgba(74, 140, 247, 0.1);
    color: #2f6fd0;
}

.ocr-status-badge.downloading {
    border-color: rgba(47, 128, 237, 0.4);
    background: rgba(47, 128, 237, 0.12);
    color: #1f67c1;
}

.ocr-status-badge.enabled {
    border-color: rgba(46, 157, 87, 0.4);
    background: rgba(46, 157, 87, 0.12);
    color: #237843;
}

.ocr-status-badge.error {
    border-color: rgba(192, 57, 43, 0.35);
    background: rgba(192, 57, 43, 0.1);
    color: #a93226;
}

.ocr-status-separator {
    color: #9a9a9a;
    font-size: 13px;
}

.ocr-download-actions {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.ocr-download-progress {
    margin: 8px 0 2px;
    height: 6px;
    background: #ececec;
    border-radius: 999px;
    overflow: hidden;
}

.ocr-download-progress-bar {
    height: 100%;
    background: color-primary;
    transition: width 0.2s linear;
}

.ocr-action-button {
    border: none;
    border-radius: 6px;
    padding: 6px 12px;
    background: color-primary;
    color: white;
    cursor: pointer;
}

.ocr-action-button.enable {
    background: #2e9d57;
}

.ocr-action-button.secondary {
    background: #e8e8e8;
    color: #333;
}

.ocr-action-button.danger {
    border: 1px solid rgba(192, 57, 43, 0.35);
    background: rgba(192, 57, 43, 0.1);
    color: #a93226;
}

.ocr-action-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.ocr-download-error {
    margin-top: 8px;
    color: #c0392b;
    font-size: 13px;
}

.ocr-download-error.inline {
    margin-top: 8px;
    margin-bottom: 0;
}

.ocr-download-link {
    color: color-primary;
    text-decoration: none;
}

.ocr-download-link:hover {
    text-decoration: underline;
}

.ocr-upload-dialog-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
    box-sizing: border-box;
    background: rgba(0, 0, 0, 0.35);
}

.ocr-upload-dialog {
    width: 520px;
    max-width: calc(100vw - 48px);
    box-sizing: border-box;
    padding: 20px;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.18);
}

.ocr-upload-dialog-title {
    color: #222;
    font-size: 18px;
    font-weight: bold;
    line-height: 1.4;
}

.ocr-upload-dialog-description {
    margin-top: 8px;
    color: #666;
    font-size: 13px;
    line-height: 1.6;
}

.ocr-upload-dialog-source {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-top: 16px;
    padding: 12px;
    border: 1px solid #e5e5e5;
    border-radius: 6px;
    background: #fafafa;
    color: #555;
    font-size: 13px;
    line-height: 1.5;
    word-break: break-all;
}

.ocr-upload-dialog-source-label {
    color: #333;
    font-weight: bold;
}

.ocr-upload-dialog-actions {
    display: flex;
    justify-content: flex-end;
    gap: 8px;
    margin-top: 18px;
}

.space {
    display: inline-block;
    width: 5px;
}

footer {
    padding: 5% 0;
    text-align: center;
    font-size: medium;
}

.footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
}

.github-icon {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
}
