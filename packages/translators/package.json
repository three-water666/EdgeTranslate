{
    "name": "@edge_translate/translators",
    "version": "0.1.4",
    "description": "Collection of translators with unified interface.",
    "keywords": [
        "translate",
        "translator"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build && tsc --emitDeclarationOnly",
        "lint": "node ../../scripts/run-eslint.js packages/translators .eslintrc.js \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\" \"*.config.js\" \"*.config.ts\" \"*.setup.js\"",
        "lint:fix": "pnpm lint --fix",
        "test": "jest"
    },
    "files": [
        "dist"
    ],
    "main": "dist/translators.umd.js",
    "unpkg": "dist/translators.iife.js",
    "module": "./dist/translators.es.js",
    "types": "./dist/types/index.d.ts",
    "devDependencies": {
        "@types/chrome": "^0.0.190",
        "@types/jest": "^28.1.3",
        "jest": "^28.1.1",
        "jest-chrome": "^0.8.0",
        "jest-environment-jsdom": "^28.1.1",
        "ts-jest": "^28.0.5",
        "typescript": "^5.9.3",
        "vite": "^2.9.13"
    },
    "peerDependencies": {
        "axios": "^1.15.0"
    }
}
