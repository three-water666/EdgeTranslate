{
    "private": true,
    "description": "A translator extension.",
    "keywords": [
        "Edge Translate",
        "侧边翻译"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/three-water666/EdgeTranslate.git"
    },
    "scripts": {
        "preinstall": "node scripts/enforce-pnpm.js",
        "postinstall": "node scripts/patch-husky-pnpm.js",
        "build": "turbo run build",
        "test": "turbo run test --concurrency=1",
        "format:staged": "node scripts/format-staged-files.js",
        "lint:staged": "node scripts/lint-staged-files.js",
        "check:staged-eol": "node scripts/check-staged-eol.js",
        "dev:chrome": "turbo run dev:chrome --filter=edge_translate",
        "build:chrome": "turbo run build:chrome --filter=edge_translate",
        "pack:chrome": "turbo run pack:chrome --filter=edge_translate"
    },
    "devDependencies": {
        "@commitlint/cli": "^13.2.1",
        "@commitlint/config-conventional": "^13.2.0",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^7.32.0",
        "eslint-config-preact": "^1.3.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-html": "^6.2.0",
        "eslint-plugin-prettier": "^3.4.1",
        "husky": "^4.3.8",
        "jest": "^27.5.1",
        "prettier": "^2.6.0",
        "turbo": "1.13.4"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "husky": {
        "hooks": {
            "pre-commit": "pnpm format:staged && pnpm lint:staged && pnpm check:staged-eol",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "packageManager": "pnpm@10.8.1"
}
