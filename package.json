{
    "private": true,
    "description": "A translator extension.",
    "keywords": [
        "Edge Translate",
        "侧边翻译"
    ],
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/three-water666/EdgeTranslate.git"
    },
    "scripts": {
        "preinstall": "node scripts/enforce-pnpm.js",
        "prepare": "husky",
        "build": "turbo run build",
        "lint": "node scripts/run-workspace-script.js lint",
        "lint:fix": "node scripts/run-workspace-script.js lint:fix",
        "package": "turbo run package --filter=edge_translate",
        "test": "turbo run test --concurrency=1",
        "format:staged": "node scripts/format-staged-files.js",
        "lint:staged": "node scripts/lint-staged-files.js",
        "check:staged-eol": "node scripts/check-staged-eol.js",
        "dev": "turbo run dev"
    },
    "devDependencies": {
        "@commitlint/cli": "^13.2.1",
        "@commitlint/config-conventional": "^13.2.0",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^7.32.0",
        "eslint-config-preact": "^1.3.0",
        "eslint-config-prettier": "^8.5.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-html": "^6.2.0",
        "eslint-plugin-prettier": "^3.4.1",
        "husky": "9.1.7",
        "jest": "^28.1.3",
        "prettier": "^2.6.0",
        "turbo": "1.13.4"
    },
    "config": {
        "commitizen": {
            "path": "./node_modules/cz-conventional-changelog"
        }
    },
    "packageManager": "pnpm@10.8.1"
}
